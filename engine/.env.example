# Tree Frog Engine — environment configuration
# Copy to .env and fill in real values.
#
# For secrets, prefer the *_FILE pattern so the raw value never lands
# in this file (which may be backed up, committed by mistake, etc.):
#
#   sudo mkdir -p /root/.secrets && sudo chmod 700 /root/.secrets
#   echo -n 'your-real-cf-token' | sudo tee /root/.secrets/cf.token >/dev/null
#   echo -n '32-bytes-of-randomness' | sudo tee /root/.secrets/admin.token >/dev/null
#   sudo chmod 600 /root/.secrets/*
#
# docker-compose.yml bind-mounts /root/.secrets → /secrets (ro) inside
# the container, so the in-container path is /secrets/... not
# /root/.secrets/...:
#
#   CF_API_TOKEN_FILE=/secrets/cf.token
#   ADMIN_TOKEN_FILE=/secrets/admin.token
#
# The engine reads ${VAR}_FILE before ${VAR}, so you can mix-and-match.

# --- Cloudflare (used by the KV publisher) ---
CF_API_TOKEN=
CF_API_TOKEN_FILE=/secrets/cf.token
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=

# --- Admin API ---
ADMIN_TOKEN=change-me-32-bytes-of-randomness
ADMIN_TOKEN_FILE=
# Bind address. With `network_mode: host` in docker-compose.yml, the
# engine shares the host's network namespace — 127.0.0.1 only accepts
# connections from the host itself. Tailscale traffic arrives on the
# host's 100.x interface, so we bind to 0.0.0.0 to accept it. This is
# safe ONLY because UFW (or your equivalent firewall) restricts port
# 8000 to the Tailscale subnet 100.64.0.0/10. See docs/vps-deploy.md
# §2.3 for the `ufw allow from 100.64.0.0/10 to any port 8000` rule.
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8000

# --- Engine behavior ---
LOG_LEVEL=INFO
HEALTH_CONCURRENCY=50
HEALTH_TIMEOUT_SEC=5
HEALTH_CADENCE_SEC=1800          # 30 minutes
HEALTH_OFFLINE_DISABLE_HOURS=72
DATA_DIR=/app/data
LOG_DIR=/app/logs
DB_PATH=/app/data/treefrog.db

# --- Health-check tuning ---
HEALTH_MANIFEST_BYTES=16384      # first 16 KB sniff of .m3u8
HEALTH_RECENT_FAILURE_BACKOFF=300  # 5 min between rechecks of recently-failed streams
