# Tree Frog Engine — environment configuration
# Copy to .env and fill in real values.

# --- Cloudflare (used by the KV publisher) ---
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=

# --- Admin API ---
ADMIN_TOKEN=change-me-32-bytes-of-randomness
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8000

# --- Engine behavior ---
LOG_LEVEL=INFO
HEALTH_CONCURRENCY=50
HEALTH_TIMEOUT_SEC=5
HEALTH_CADENCE_SEC=1800          # 30 minutes
HEALTH_OFFLINE_DISABLE_HOURS=72
DATA_DIR=/app/data
LOG_DIR=/app/logs
DB_PATH=/app/data/treefrog.db

# --- Health-check tuning ---
HEALTH_MANIFEST_BYTES=16384      # first 16 KB sniff of .m3u8
HEALTH_RECENT_FAILURE_BACKOFF=300  # 5 min between rechecks of recently-failed streams
